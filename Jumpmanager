-- ============================================================
--  JumpManager  (ServerScript)
--  Place inside: ServerScriptService
-- ============================================================

local CONFIG = {
	MinJumps    = 5,
	HitCooldown = 0.8,
	HitRange    = 20,   -- increased from 8 → 20 studs (much easier to hit)
}

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ╔══════════════════════════════════════════╗
-- ║   CREATE REMOTES FOLDER                  ║
-- ║   Pre-create in ReplicatedStorage so     ║
-- ║   clients can always find them           ║
-- ╚══════════════════════════════════════════╝

-- Remove old folder if it exists (clean start)
local old = ReplicatedStorage:FindFirstChild("JumpRemotes")
if old then old:Destroy() end

local Remotes = Instance.new("Folder")
Remotes.Name  = "JumpRemotes"
Remotes.Parent = ReplicatedStorage

local RequestHit = Instance.new("RemoteEvent")
RequestHit.Name  = "RequestHit"
RequestHit.Parent = Remotes

local JumpCountChanged = Instance.new("RemoteEvent")
JumpCountChanged.Name  = "JumpCountChanged"
JumpCountChanged.Parent = Remotes

local GotHit = Instance.new("RemoteEvent")
GotHit.Name   = "GotHit"
GotHit.Parent = Remotes

print("[JumpManager] Remotes created in ReplicatedStorage")

-- ╔══════════════════════════════════════════╗
-- ║   JUMP COUNT STORAGE                     ║
-- ╚══════════════════════════════════════════╝

local playerJumps = {}
local lastHitTime = {}

local function getJumps(player)
	return playerJumps[player] or CONFIG.MinJumps
end

local function setJumps(player, amount)
	playerJumps[player] = math.max(amount, CONFIG.MinJumps)
	JumpCountChanged:FireClient(player, playerJumps[player])
	print("[JumpManager] SET", player.Name, "→", playerJumps[player], "jumps")
end

-- ╔══════════════════════════════════════════╗
-- ║   PLAYER SETUP                           ║
-- ╚══════════════════════════════════════════╝

local function setupPlayer(player)
	playerJumps[player] = CONFIG.MinJumps
	lastHitTime[player] = 0
	print("[JumpManager] Registered player:", player.Name)

	player.CharacterAdded:Connect(function()
		task.wait(0.8)  -- give client extra time to load
		print("[JumpManager] Sending initial jumps to", player.Name, ":", getJumps(player))
		JumpCountChanged:FireClient(player, getJumps(player))
	end)
end

-- Handle players already in game when script runs
for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end

Players.PlayerAdded:Connect(setupPlayer)

Players.PlayerRemoving:Connect(function(player)
	playerJumps[player] = nil
	lastHitTime[player] = nil
end)

-- ╔══════════════════════════════════════════╗
-- ║   HIT HANDLER                            ║
-- ╚══════════════════════════════════════════╝

RequestHit.OnServerEvent:Connect(function(attacker, targetPlayer)
	print("[JumpManager] Hit request from:", attacker.Name, "→ target:", tostring(targetPlayer))

	-- Valid player target
	if not targetPlayer or not targetPlayer:IsA("Player") then
		print("[JumpManager] REJECTED: invalid target")
		return
	end

	-- No self-hit
	if attacker == targetPlayer then
		print("[JumpManager] REJECTED: self hit")
		return
	end

	-- Cooldown
	local now = tick()
	local timeSinceLast = now - (lastHitTime[attacker] or 0)
	if timeSinceLast < CONFIG.HitCooldown then
		print("[JumpManager] REJECTED: cooldown", timeSinceLast)
		return
	end

	-- Characters exist
	local atkChar = attacker.Character
	local tgtChar = targetPlayer.Character
	if not atkChar or not tgtChar then
		print("[JumpManager] REJECTED: missing character")
		return
	end

	local atkHRP  = atkChar:FindFirstChild("HumanoidRootPart")
	local tgtHRP  = tgtChar:FindFirstChild("HumanoidRootPart")
	if not atkHRP or not tgtHRP then
		print("[JumpManager] REJECTED: missing HRP")
		return
	end

	local tgtHuman = tgtChar:FindFirstChild("Humanoid")
	if not tgtHuman or tgtHuman.Health <= 0 then
		print("[JumpManager] REJECTED: target dead")
		return
	end

	-- Range check
	local dist = (atkHRP.Position - tgtHRP.Position).Magnitude
	print("[JumpManager] Distance:", dist, "/ Range:", CONFIG.HitRange)
	if dist > CONFIG.HitRange then
		print("[JumpManager] REJECTED: out of range")
		return
	end

	-- ── All checks passed — transfer jump ───
	lastHitTime[attacker] = now

	local victimJumps   = getJumps(targetPlayer)
	local attackerJumps = getJumps(attacker)

	-- Victim loses 1 only if above the floor
	local victimNew   = math.max(victimJumps - 1, CONFIG.MinJumps)
	-- Attacker ALWAYS gains 1 on a successful hit — that's the reward!
	local attackerNew = attackerJumps + 1

	setJumps(targetPlayer, victimNew)
	setJumps(attacker, attackerNew)

	GotHit:FireClient(targetPlayer, attacker.Name)

	print(string.format("[JumpManager] ✅ %s hit %s! %s: %d→%d | %s: %d→%d",
		attacker.Name, targetPlayer.Name,
		targetPlayer.Name, victimJumps, victimNew,
		attacker.Name, attackerJumps, attackerNew))
end)

print("[JumpManager] Running! HitRange:", CONFIG.HitRange)
